{
  "name": "server",
  "version": "1.0.0",
  "description": "Backend for Level Up (auth, API, optional sync) will be added in a future phase. V1 of the app is client-only and uses local storage.",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json && node copy-assets.js",
    "start": "node -r tsconfig-paths/register --require dotenv/config dist/server.js",
    "dev": "nodemon --exec \"ts-node -r tsconfig-paths/register src/server.ts\"",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "typeorm": "ts-node-dev -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:generate": "pnpm typeorm migration:generate -d src/config/database.config.ts",
    "migration:run": "pnpm typeorm migration:run -d src/config/database.config.ts",
    "migration:revert": "pnpm typeorm migration:revert -d src/config/database.config.ts",
    "migration:show": "pnpm typeorm migration:show -d src/config/database.config.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "express-status-monitor": "^1.3.4",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "nodemon": "^3.1.14",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.28",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-status-monitor": "^1.3.3",
    "@types/node": "^25.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.2"
  }
}
